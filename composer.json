            "JdSpApi\\Sp\\Product\\V0\\Api\\": "lib/sp/product/v0/api/",
            "JdSpApi\\Sp\\Product\\V0\\Model\\": "lib/sp/product/v0/model/",
            "JdSpApi\\Sp\\Seller\\V0\\Api\\": "lib/sp/seller/v0/api/",
            "JdSpApi\\Sp\\Seller\\V0\\Model\\": "lib/sp/seller/v0/model/",
            "JdSpApi\\Sp\\Support\\V0\\Api\\": "lib/sp/support/v0/api/",
            "JdSpApi\\Sp\\Support\\V0\\Model\\": "lib/sp/support/v0/model/",
