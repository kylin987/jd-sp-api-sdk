    "autoload": {
        "psr-4": {
            "JdSpApi\\Open\\Security\\V0\\Api\\": "lib/open/security/v0/api/",
            "JdSpApi\\Open\\Security\\V0\\Model\\": "lib/open/security/v0/model/",
            "JdSpApi\\Sp\\Address\\V0\\Api\\": "lib/sp/address/v0/api/",
            "JdSpApi\\Sp\\Address\\V0\\Model\\": "lib/sp/address/v0/model/",
            "JdSpApi\\Sp\\Aftercare\\V0\\Api\\": "lib/sp/aftercare/v0/api/",
            "JdSpApi\\Sp\\Aftercare\\V0\\Model\\": "lib/sp/aftercare/v0/model/",
            "JdSpApi\\Sp\\C2m\\V0\\Api\\": "lib/sp/c2m/v0/api/",
            "JdSpApi\\Sp\\C2m\\V0\\Model\\": "lib/sp/c2m/v0/model/",
            "JdSpApi\\Sp\\Finance\\V0\\Api\\": "lib/sp/finance/v0/api/",
            "JdSpApi\\Sp\\Finance\\V0\\Model\\": "lib/sp/finance/v0/model/",
            "JdSpApi\\Sp\\Order\\V0\\Api\\": "lib/sp/order/v0/api/",
