{
    "name": "kylin987/jd-sp-api-sdk",
    "description": "京东商家开放平台 SP-API PHP SDK",
    "type": "library",
    "license": "MIT",
    "version": "4.0.0",
    "authors": [
        {
            "name": "kylin987"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "com\\jd\\openapi\\apiClient\\": "",
            "com\\jd\\openapi\\apiClient\\open\\security\\v0\\api\\": "open/security/v0/api/",
            "com\\jd\\openapi\\apiClient\\open\\security\\v0\\model\\": "open/security/v0/model/",
            "com\\jd\\openapi\\apiClient\\sp\\address\\v0\\api\\": "sp/address/v0/api/",
            "com\\jd\\openapi\\apiClient\\sp\\address\\v0\\model\\": "sp/address/v0/model/",
            "com\\jd\\openapi\\apiClient\\sp\\aftercare\\v0\\api\\": "sp/aftercare/v0/api/",
            "com\\jd\\openapi\\apiClient\\sp\\aftercare\\v0\\model\\": "sp/aftercare/v0/model/",
            "com\\jd\\openapi\\apiClient\\sp\\c2m\\v0\\api\\": "sp/c2m/v0/api/",
            "com\\jd\\openapi\\apiClient\\sp\\c2m\\v0\\model\\": "sp/c2m/v0/model/",
            "com\\jd\\openapi\\apiClient\\sp\\finance\\v0\\api\\": "sp/finance/v0/api/",
            "com\\jd\\openapi\\apiClient\\sp\\finance\\v0\\model\\": "sp/finance/v0/model/",
            "com\\jd\\openapi\\apiClient\\sp\\order\\v0\\api\\": "sp/order/v0/api/",
            "com\\jd\\openapi\\apiClient\\sp\\order\\v0\\model\\": "sp/order/v0/model/",
            "com\\jd\\openapi\\apiClient\\sp\\product\\v0\\api\\": "sp/product/v0/api/",
            "com\\jd\\openapi\\apiClient\\sp\\product\\v0\\model\\": "sp/product/v0/model/",
            "com\\jd\\openapi\\apiClient\\sp\\seller\\v0\\api\\": "sp/seller/v0/api/",
            "com\\jd\\openapi\\apiClient\\sp\\seller\\v0\\model\\": "sp/seller/v0/model/",
            "com\\jd\\openapi\\apiClient\\sp\\support\\v0\\api\\": "sp/support/v0/api/",
            "com\\jd\\openapi\\apiClient\\sp\\support\\v0\\model\\": "sp/support/v0/model/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JdSpApiSdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "keywords": ["jd", "jingdong", "sp-api", "sdk", "php"],
    "minimum-stability": "stable"
}
